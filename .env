# LLRT 项目的 Android arm64 目标的环境变量
export ANDROID_NDK_HOME=/home/vhxnyu/android-ndk-r27c
export ANDROID_NDK=/home/vhxnyu/android-ndk-r27c
export NDK_HOME=/home/vhxnyu/android-ndk-r27c
export PATH=$ANDROID_NDK_HOME/toolchains/llvm/prebuilt/linux-x86_64/bin:$PATH

export ANDROID_ABI=arm64-v8a
export ANDROID_PLATFORM=android-24

export TOOLCHAIN=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64
export CMAKE_TOOLCHAIN_FILE_aarch64_linux_android=$ANDROID_NDK/build/cmake/android.toolchain.cmake
export AR_aarch64_linux_android=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/llvm-ar
export CMAKE_TOOLCHAIN_FILE=$ANDROID_NDK/build/cmake/android.toolchain.cmake
export CMAKE_ARGS="-DANDROID_ABI=arm64-v8a -DANDROID_PLATFORM=android-24"
export CC_aarch64_linux_android=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang
export CXX_aarch64_linux_android=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang++
export CLANG_PATH=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/clang
export CARGO_TARGET_AARCH64_LINUX_ANDROID_LINKER=$ANDROID_NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang
export CARGO_TARGET_AARCH64_LINUX_ANDROID_CC=$CC_aarch64_linux_android
export CARGO_TARGET_AARCH64_LINUX_ANDROID_AR=$AR_aarch64_linux_android
